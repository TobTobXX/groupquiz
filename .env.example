# Frontend credentials — loaded by Vite at build time.
# Copy this file to .env (gitignored) and fill in your production values.
#
# For LOCAL DEVELOPMENT, create .env.local (also gitignored) with the local
# Supabase credentials printed by `supabase start`.  Vite loads .env.local with
# higher priority than .env, so production values in .env are not affected.
#
#   .env.local contents:
#     VITE_SUPABASE_URL=http://127.0.0.1:54321
#     VITE_SUPABASE_ANON_KEY=<anon key from `supabase start` output>

# Production Supabase project (Project Overview → Project URL)
VITE_SUPABASE_URL=https://<project-id>.supabase.co

# Production anon key (Project Settings → API Keys → Publishable key)
VITE_SUPABASE_ANON_KEY=

# Edge Function secrets are NOT Vite env vars — they are set on the Supabase
# project via `supabase secrets set` and never go in this file.
# See supabase/functions/.env.example for the full list.
