# Edge Function secrets for local development.
# Copy this file to supabase/functions/.env (gitignored) and fill in dev/test values.
# Pass it when serving functions locally:
#   supabase functions serve --env-file supabase/functions/.env
#
# For production, set these once via:
#   supabase secrets set STRIPE_SECRET_KEY=sk_live_...
#   (and so on for each key)
#
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are injected automatically by the
# local runtime — do NOT add them here.
#
# SB_JWT_ISSUER must match VITE_SUPABASE_URL (from .env.local) + "/auth/v1".
# The local Edge Runtime injects an internal Docker URL as SUPABASE_URL, which
# doesn't match the issuer in JWTs issued to the browser. This override fixes it.
SB_JWT_ISSUER=http://127.0.0.1:54321/auth/v1

STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...
